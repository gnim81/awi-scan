{
  "name": "awi-scan",
  "version": "0.2.0",
  "description": "Detect Agentic Workflow Injection risks in GitHub Actions workflows.",
  "type": "module",
  "license": "MIT",
  "author": "awi-scan contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gnim81/awi-scan.git"
  },
  "homepage": "https://github.com/gnim81/awi-scan#readme",
  "bugs": {
    "url": "https://github.com/gnim81/awi-scan/issues"
  },
  "keywords": [
    "github-actions",
    "security",
    "ai",
    "agents",
    "prompt-injection",
    "sarif"
  ],
  "bin": {
    "awi-scan": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "action.yml",
    "docs/configuration.md",
    "docs/examples.md",
    "docs/releasing.md",
    "docs/rules.md",
    "docs/threat-model.md",
    "docs/pull-request-target.md",
    "docs/agent-actions.md",
    "docs/assets",
    "docs/false-positives.md",
    "docs/sarif-upload.md",
    "README.md",
    "SECURITY.md",
    "CONTRIBUTING.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "check": "npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "fast-glob": "^3.3.3",
    "ignore": "^5.3.2",
    "picocolors": "^1.1.1",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@types/node": "^20.17.10",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^4.1.7"
  }
}
